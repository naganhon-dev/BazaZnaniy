rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isCreatingDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    function hasAllRequiredFieldsForDocument() {
      return request.resource.data.keys().hasAll(["uid", "title", "content", "createdAt"]);
    }
    
    function hasAllRequiredFieldsForMessage() {
      return request.resource.data.keys().hasAll(["uid", "role", "content", "createdAt"]);
    }

    function isValidDocument() {
      return hasAllRequiredFieldsForDocument()
        && request.resource.data.uid is string
        && request.resource.data.title is string
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1048576 // Avoid > 1MB limit check (Firestore hard limit, but safe to check)
        && request.resource.data.createdAt is number;
    }

    function isValidMessage() {
      return hasAllRequiredFieldsForMessage()
        && request.resource.data.uid is string
        && request.resource.data.role in ["user", "assistant"]
        && request.resource.data.content is string
        && request.resource.data.createdAt is number;
    }

    match /documents/{docId} {
      allow read: if isDocOwner();
      allow create: if isCreatingDocOwner() && isValidDocument();
      allow delete: if isDocOwner();
      allow update: if false; // Documents are immutable
    }

    match /messages/{msgId} {
      allow read: if isDocOwner();
      allow create: if isCreatingDocOwner() && isValidMessage();
      allow delete: if isDocOwner();
      allow update: if false; // Messages are immutable
    }
  }
}
